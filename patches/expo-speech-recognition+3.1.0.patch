@@ -0,0 +1,32 @@
+//
+// SoulTalkSpeechExceptionCatcher.h
+//
+// so-p1un: ObjC shim that wraps a Swift closure in @try/@catch so callers
+// can recover from NSExceptions raised by Cocoa APIs (notably
+// AVAudioEngine.connect:to:format: during audio-route changes). Swift's
+// do/catch only catches Swift Errors, NOT Objective-C NSExceptions; a
+// raised NSException with no @try handler triggers __abort_message and
+// SIGABRTs the process. This file is the catch-all safety net that
+// keeps the so-iy21 fallback path reachable.
+//
+// Lives inside node_modules/expo-speech-recognition/ios/ so it ships
+// with the Pod's autolinked source_files glob and is visible to the
+// module's Swift sources via the auto-generated umbrella header.
+// Patch shipped via patch-package; postinstall in package.json reapplies
+// on every npm/yarn install.
+//
+
+#import <Foundation/Foundation.h>
+
+NS_ASSUME_NONNULL_BEGIN
+
+@interface SoulTalkSpeechExceptionCatcher : NSObject
+
+/// Runs `block` inside an @try/@catch. Returns nil on success, or the
+/// caught NSException on raise. The block is NS_NOESCAPE so Swift can
+/// pass non-escaping closures.
++ (NSException * _Nullable)tryBlock:(NS_NOESCAPE void (^)(void))block NS_SWIFT_NAME(catching(_:));
+
+@end
+
+NS_ASSUME_NONNULL_END
diff --git a/node_modules/expo-speech-recognition/ios/SoulTalkSpeechExceptionCatcher.m b/node_modules/expo-speech-recognition/ios/SoulTalkSpeechExceptionCatcher.m
new file mode 100644
index 0000000..4444444
--- /dev/null
+++ b/node_modules/expo-speech-recognition/ios/SoulTalkSpeechExceptionCatcher.m
@@ -0,0 +1,20 @@
+//
+// SoulTalkSpeechExceptionCatcher.m
+//
+// so-p1un: see header for rationale.
+//
+
+#import "SoulTalkSpeechExceptionCatcher.h"
+
+@implementation SoulTalkSpeechExceptionCatcher
+
++ (NSException * _Nullable)tryBlock:(NS_NOESCAPE void (^)(void))block {
+  @try {
+    block();
+    return nil;
+  } @catch (NSException *exception) {
+    return exception;
+  }
+}
+
+@end
